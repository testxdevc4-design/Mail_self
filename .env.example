# ── Required secrets ──────────────────────────────────────────────────────────

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (from @userinfobot)
TELEGRAM_ADMIN_UID=

# Supabase project URL (from Project Settings → API)
SUPABASE_URL=

# Supabase service role key – NEVER expose this in the browser
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis (TLS URL)  e.g. rediss://default:<password>@<host>.upstash.io:6379
# For local dev, use: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# JWT signing secret – minimum 64 characters
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET=

# AES-256 encryption key – exactly 64 hex characters (32 bytes)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=

# ── Optional settings ─────────────────────────────────────────────────────────

# Environment: 'production' or 'development'
ENV=development

# Port for the API service
PORT=3000

# Comma-separated list of allowed CORS origins
# Leave blank to allow all origins (development only)
ALLOWED_ORIGINS=http://localhost:3000
